---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const guides = await getCollection('guides', g => !g.data.draft);
guides.sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

const featured = guides.filter(g => g.data.featured);
const regular = guides.filter(g => !g.data.featured);
---

<BaseLayout title="攻略" description="《英雄无敌：旧日纪元》中文攻略：新手入门、阵营指南、流派构筑、战役全流程、多人对战。">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">CHAPTER II · 入门之路</p>
      <h1>攻略</h1>
      <p class="lede">从第一周到史诗终战 · 从入门到精通</p>
    </div>
  </section>

  {featured.length > 0 && (
    <section class="container content-section">
      <h2 class="section-title">精选</h2>
      <div class="featured-grid">
        {featured.map(g => (
          <a class="featured-card" href={`/guides/${g.slug}/`}>
            <span class="featured-tag">精选</span>
            <span class="category">{g.data.category}</span>
            <h3>{g.data.title}</h3>
            <p>{g.data.description}</p>
            <div class="guide-meta">
              <span>{g.data.author}</span>
              <span>·</span>
              <span>{g.data.publishedAt}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {regular.length > 0 && (
    <section class="container content-section">
      <h2 class="section-title">全部攻略</h2>
      <div class="guide-list">
        {regular.map(g => (
          <a class="guide-row" href={`/guides/${g.slug}/`}>
            <div class="guide-info">
              <span class="category">{g.data.category}</span>
              <h3>{g.data.title}</h3>
              <p>{g.data.description}</p>
            </div>
            <span class="guide-date">{g.data.publishedAt}</span>
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .page-hero { padding: var(--space-16) 0 var(--space-8); text-align: center; }
  .page-hero h1 { margin: var(--space-3) 0; }
  .lede { color: var(--ink-secondary); font-size: 1.05rem; }

  .content-section { padding-block: var(--space-8); }

  .section-title {
    font-family: var(--font-cn);
    font-size: 1.5rem;
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: var(--border-soft);
  }

  /* featured */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-4);
  }

  .featured-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-6);
    background: linear-gradient(135deg, rgba(201, 162, 94, 0.10), var(--bg-elevated));
    border: 1px solid var(--gold-deep);
    transition: all 220ms ease;
    color: var(--ink-primary);
    text-shadow: none;
  }

  .featured-card:hover {
    border-color: var(--gold);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.4);
    color: var(--ink-primary);
  }

  .featured-tag {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    padding: 2px var(--space-2);
    font-family: var(--font-display);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--bg-deep);
    background: var(--gold);
    text-transform: uppercase;
    border-radius: var(--radius-sm);
  }

  .category {
    font-family: var(--font-display);
    font-size: 0.68rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .featured-card h3 {
    font-size: 1.3rem;
    margin: 0;
  }

  .featured-card p {
    color: var(--ink-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .guide-meta {
    display: flex;
    gap: var(--space-2);
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: var(--ink-muted);
    text-transform: uppercase;
    margin-top: var(--space-3);
  }

  /* list */
  .guide-list {
    display: grid;
    gap: var(--space-3);
  }

  .guide-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-6);
    padding: var(--space-5);
    background: var(--bg-elevated);
    border: var(--border-faint);
    transition: all 200ms ease;
    color: var(--ink-primary);
    text-shadow: none;
  }

  .guide-row:hover {
    border-color: var(--gold);
    color: var(--ink-primary);
  }

  .guide-info { flex: 1; }
  .guide-info h3 {
    font-size: 1.1rem;
    margin: var(--space-2) 0;
  }
  .guide-info p {
    margin: 0;
    font-size: 0.92rem;
    color: var(--ink-secondary);
  }

  .guide-date {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--ink-muted);
    flex-shrink: 0;
  }
</style>
